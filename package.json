{
  "name": "brasil-kit",
  "version": "1.1.1",
  "description": "Utilitários para dados brasileiros — CPF, CNPJ, CEP, telefone. Validação, formatação e geração.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check ./src ./tests",
    "lint:fix": "biome check --write ./src ./tests",
    "format": "biome format --write ./src ./tests",
    "check": "biome check ./src ./tests && tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "release": "changeset publish"
  },
  "keywords": [
    "brasil",
    "brazil",
    "cpf",
    "cnpj",
    "cep",
    "telefone",
    "phone",
    "validacao",
    "validation",
    "formatacao",
    "format",
    "utils",
    "utilities"
  ],
  "author": "kauan da silva ferreira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvakwan1/brasil-kit.git"
  },
  "bugs": {
    "url": "https://github.com/silvakwan1/brasil-kit/issues"
  },
  "homepage": "https://www.npmjs.com/package/brasil-kit",
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
